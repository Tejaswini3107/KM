@{
    ViewData["Title"] = "Admin Dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-light">
    <div class="container mt-5">
        <h2 class="mb-4">Smart Waste Management Dashboard</h2>
        <div class="row">
            <div class="col-md-6">
                <canvas id="bin1Chart"></canvas>
            </div>
            <div class="col-md-6">
                <canvas id="bin2Chart"></canvas>
            </div>
        </div>
        <div class="row mt-4">
            <div class="col-md-6">
                <canvas id="bin3Chart"></canvas>
            </div>
            <div class="col-md-6">
                <canvas id="alertChart"></canvas>
            </div>
        </div>
    </div>
    <script>
        async function fetchHistory() {
            const res = await fetch('/api/history?limit=50');
            const data = await res.json();
            return data.data || [];
        }
        function makeChart(ctx, label, data, color) {
            return new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.map(x => x.timestamp),
                    datasets: [{
                        label: label,
                        data: data.map(x => x.value),
                        borderColor: color,
                        fill: false
                    }]
                },
                options: { responsive: true, plugins: { legend: { display: true } } }
            });
        }
        fetchHistory().then(history => {
            makeChart(document.getElementById('bin1Chart').getContext('2d'), 'Bin 1 Fill', history.map(x => ({ timestamp: x.timestamp, value: x.bin1Fill })), 'red');
            makeChart(document.getElementById('bin2Chart').getContext('2d'), 'Bin 2 Light', history.map(x => ({ timestamp: x.timestamp, value: x.bin2Light })), 'blue');
            makeChart(document.getElementById('bin3Chart').getContext('2d'), 'Bin 3 Water', history.map(x => ({ timestamp: x.timestamp, value: x.bin3Water })), 'green');
            makeChart(document.getElementById('alertChart').getContext('2d'), 'Alerts', history.map(x => ({ timestamp: x.timestamp, value: x.alert })), 'orange');
        });
    </script>
</body>
</html>
