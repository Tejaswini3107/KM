@{
    ViewData["Title"] = "Admin Dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --ink: #0f172a;
            --muted: #475569;
            --panel: rgba(255,255,255,.9);
            --panel-border: rgba(148,163,184,.28);
            --accent: #0f766e;
            --accent-2: #ca8a04;
            --accent-3: #b91c1c;
        }
        body {
            background: radial-gradient(circle at top left, #e2f7f6 0, #f8fafc 35%, #eef2ff 100%);
            color: var(--ink);
        }
        .glass-card {
            background: var(--panel);
            border: 1px solid var(--panel-border);
            border-radius: 20px;
            box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
            backdrop-filter: blur(12px);
        }
        .metric-card {
            cursor: pointer;
            transition: transform .18s ease, box-shadow .18s ease;
        }
        .metric-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.12);
        }
        .metric-value {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.04em;
        }
        .metric-label {
            color: var(--muted);
            font-size: .92rem;
        }
        .state-chip {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: .35rem .7rem;
            border-radius: 999px;
            border: 1px solid rgba(148,163,184,.25);
            background: rgba(255,255,255,.8);
            color: #0f172a;
            font-size: .78rem;
            font-weight: 700;
            text-decoration: none;
            transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
        }
        .state-chip:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
            background: rgba(255,255,255,1);
            color: #0f172a;
        }
        .chip-group {
            display: flex;
            flex-wrap: wrap;
            gap: .45rem;
            margin-top: .75rem;
        }
    </style>
</head>
<body>
    <div class="container py-4 py-lg-5">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <h2 class="mb-1 fw-bold">Smart Waste Management Dashboard</h2>
                <div class="text-muted">Live sensor, truck, and log state with manual refresh and auto-refresh.</div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary" id="lastUpdatedBtn" type="button" onclick="refreshDashboard()">Refresh now</button>
                <a class="btn btn-outline-primary" href="/admin/history">History</a>
                <a class="btn btn-dark" href="/admin/logs">Open Logs</a>
                <a class="btn btn-outline-danger" href="/admin/logout">Logout</a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="glass-card metric-card p-4 h-100">
                    <div class="metric-label">Sensor Snapshot</div>
                    <div class="metric-value" id="sensorMetric">--</div>
                    <div class="text-muted small" id="sensorDetail">Waiting for data...</div>
                    <div class="chip-group">
                        <a class="state-chip" href="/admin/history?bin1State=FULL">Bin1 FULL</a>
                        <a class="state-chip" href="/admin/history?bin1State=HALF">Bin1 HALF</a>
                        <a class="state-chip" href="/admin/history?bin1State=EMPTY">Bin1 EMPTY</a>
                        <a class="state-chip" href="/admin/history?bin2State=BRIGHT">Bin2 BRIGHT</a>
                        <a class="state-chip" href="/admin/history?bin2State=DIM">Bin2 DIM</a>
                        <a class="state-chip" href="/admin/history?bin2State=DARK">Bin2 DARK</a>
                        <a class="state-chip" href="/admin/history?bin3State=FLOOD!">Bin3 FLOOD!</a>
                        <a class="state-chip" href="/admin/history?bin3State=DAMP">Bin3 DAMP</a>
                        <a class="state-chip" href="/admin/history?bin3State=DRY">Bin3 DRY</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card metric-card p-4 h-100" onclick="document.getElementById('alertChart').scrollIntoView({behavior:'smooth'})">
                    <div class="metric-label">Truck Movement</div>
                    <div class="metric-value" id="truckMetric">Idle</div>
                    <div class="text-muted small" id="truckDetail">No movement received yet.</div>
                    <div class="chip-group">
                        <a class="state-chip" href="/admin/history?needsTruck=true">Truck needed</a>
                        <a class="state-chip" href="/admin/history?alert=true">Alerts only</a>
                        <a class="state-chip" href="/admin/history?source=Arduino">Arduino</a>
                        <a class="state-chip" href="/admin/history?source=Unity">Unity</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card metric-card p-4 h-100" onclick="window.location='/admin/logs'">
                    <div class="metric-label">Live Logs</div>
                    <div class="metric-value" id="logMetric">0</div>
                    <div class="text-muted small" id="logDetail">Recent log entries</div>
                    <div class="chip-group">
                        <a class="state-chip" href="/admin/logs?level=Error">Errors</a>
                        <a class="state-chip" href="/admin/logs?level=Warning">Warnings</a>
                        <a class="state-chip" href="/admin/logs?source=Update">Update</a>
                        <a class="state-chip" href="/admin/logs?source=TruckStatus">Truck</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-6">
                <div class="glass-card p-3 p-lg-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Bin 1 Fill</h5>
                        <span class="badge text-bg-success" id="alertBadge">Live</span>
                    </div>
                    <canvas id="bin1Chart"></canvas>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="glass-card p-3 p-lg-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Bin 2 Light</h5>
                        <span class="badge text-bg-warning">Bin2</span>
                    </div>
                    <canvas id="bin2Chart"></canvas>
                </div>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="glass-card p-3 p-lg-4 h-100">
                    <h5 class="mb-3">Bin 3 Water</h5>
                    <canvas id="bin3Chart"></canvas>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="glass-card p-3 p-lg-4 h-100">
                    <h5 class="mb-3">Alerts</h5>
                    <canvas id="alertChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <script>
        let bin1Chart;
        let bin2Chart;
        let bin3Chart;
        let alertChart;
        let refreshTimer;

        async function fetchOverview() {
            const res = await fetch('/api/admin/overview?historyLimit=60');
            return await res.json();
        }

        function buildSeries(history, selector, valueSelector) {
            return history.map(x => ({ timestamp: x.timestamp, value: valueSelector(x) }));
        }

        function makeChart(ctx, label, data, color, chartInstance) {
            if (chartInstance) {
                chartInstance.destroy();
            }
            return new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.map(x => x.timestamp),
                    datasets: [{
                        label: label,
                        data: data.map(x => x.value),
                        borderColor: color,
                        fill: false
                    }]
                },
                options: { responsive: true, plugins: { legend: { display: true } } }
            });
        }

        async function refreshDashboard() {
            const overview = await fetchOverview();
            const history = await (await fetch('/api/history?limit=60')).json();
            const items = history.data || [];

            const latest = overview.latestHistory || {};
            document.getElementById('sensorMetric').textContent = `${overview.totalHistoryCount || 0} samples`;
            document.getElementById('sensorDetail').textContent = latest ? `Bin1 ${latest.bin1State || '--'} | Bin2 ${latest.bin2State || '--'} | Bin3 ${latest.bin3State || '--'}` : 'Waiting for data...';
            document.getElementById('truckMetric').textContent = latest.truckState || 'Idle';
            document.getElementById('truckDetail').textContent = latest.truckLocation || (latest.truckReached ? 'Truck reached target' : 'No truck location set');
            document.getElementById('logMetric').textContent = `${overview.logCount || 0}`;
            document.getElementById('logDetail').textContent = overview.latestLog ? `${overview.latestLog.level}: ${overview.latestLog.message}` : 'No logs yet';
            document.getElementById('lastUpdatedBtn').textContent = `Refresh now (${new Date().toLocaleTimeString()})`;

            const bin1Series = buildSeries(items, 'timestamp', x => x.bin1Fill);
            const bin2Series = buildSeries(items, 'timestamp', x => x.bin2Light);
            const bin3Series = buildSeries(items, 'timestamp', x => x.bin3Water);
            const alertSeries = buildSeries(items, 'timestamp', x => x.alert);

            bin1Chart = makeChart(document.getElementById('bin1Chart').getContext('2d'), 'Bin 1 Fill', bin1Series, '#b91c1c', bin1Chart);
            bin2Chart = makeChart(document.getElementById('bin2Chart').getContext('2d'), 'Bin 2 Light', bin2Series, '#0f766e', bin2Chart);
            bin3Chart = makeChart(document.getElementById('bin3Chart').getContext('2d'), 'Bin 3 Water', bin3Series, '#2563eb', bin3Chart);
            alertChart = makeChart(document.getElementById('alertChart').getContext('2d'), 'Alerts', alertSeries, '#ca8a04', alertChart);
        }

        refreshDashboard();
        refreshTimer = setInterval(refreshDashboard, 10000);
    </script>
</body>
</html>
